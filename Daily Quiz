          frage: 'Welcher Mathematiker bewies die Unmöglichkeit der allgemeinen Lösung der Gleichung 5. Grades durch Radikale?',
          optionen: ['Niels Henrik Abel', 'Évariste Galois', 'Carl Friedrich Gauß', 'Augustin-Louis Cauchy'],
          antwort: 0,
          feedback: 'Abel bewies 1824 die Unlösbarkeit der allgemeinen quintischen Gleichung durch Radikale.'
        },
        {
          typ: 'multiple-choice',
          frage: 'Welches Land erfand das Papier?',
          optionen: ['Ägypten', 'China', 'Indien', 'Griechenland'],
          antwort: 1,
          feedback: 'Das Papier wurde im antiken China erfunden (Cai Lun, ca. 105 n. Chr.).'
        },
        {
          typ: 'freitext',
          frage: 'Wie heißt das größte Korallenriff der Welt?',
          antwort: 'Great Barrier Reef',
          feedback: 'Das Great Barrier Reef vor Australien ist das größte Korallenriff der Welt.'
        },
        {
          typ: 'multiple-choice',
          frage: 'Welches Tier wechselt nicht seine Farbe?',
          optionen: ['Chamäleon', 'Tintenfisch', 'Flunder', 'Eisbär'],
          antwort: 3,
          feedback: 'Eisbären verändern ihre Fellfarbe nicht aktiv (auch wenn sie unter UV-Licht teilweise gelblich wirken).'
        },
        {
          typ: 'multiple-choice',
          frage: 'Welche Stadt war Hauptstadt des antiken Ägyptens während des Alten Reiches?',
          optionen: ['Theben', 'Memphis', 'Alexandria', 'Karnak'],
          antwort: 1,
          feedback: 'Memphis war im Alten Reich die Hauptstadt Ägyptens.'
        },
        {
          typ: 'freitext',
          frage: 'Wer war die erste Frau im Weltall?',
          antwort: 'Walentina Tereschkowa',
          feedback: 'Walentina Tereschkowa flog 1963 als erste Frau ins Weltall.'
        },
        {
          typ: 'multiple-choice',
          frage: 'Welches Lebewesen produziert über die Hälfte des Sauerstoffs der Erde?',
          optionen: ['Wälder', 'Algen und Phytoplankton', 'Moose', 'Gräser'],
          antwort: 1,
          feedback: 'Marine Algen und Phytoplankton produzieren über die Hälfte des Sauerstoffs der Erde.'
        },
        {
          typ: 'multiple-choice',
          frage: 'Wer schrieb "Hundert Jahre Einsamkeit"?',
          optionen: ['Mario Vargas Llosa', 'Gabriel García Márquez', 'Jorge Luis Borges', 'Pablo Neruda'],
          antwort: 1,
          feedback: 'Gabriel García Márquez veröffentlichte den Roman 1967.'
        },
        {
          typ: 'freitext',
          frage: 'Wie nennt man die Wissenschaft der Sterne und Himmelskörper?',
          antwort: 'Astronomie',
          feedback: 'Die Astronomie untersucht Sterne, Planeten und das Universum.'
        },
        {
          typ: 'multiple-choice',
          frage: 'Welche Einheit misst elektrischen Strom?',
          optionen: ['Volt', 'Ampere', 'Ohm', 'Watt'],
          antwort: 1,
          feedback: 'Die elektrische Stromstärke wird in Ampere (A) gemessen.'
        }
      ];

      const heute = new Date();
      const einTag = 1000 * 60 * 60 * 24;
      const tagesNummer = Math.floor(
        (heute.getTime() - heute.getTimezoneOffset() * 60000) / einTag
      );
      const frageIndex = ((tagesNummer % fragen.length) + fragen.length) % fragen.length;
      const heutigeFrage = fragen[frageIndex];

      function quizAnzeigen() {
        if (!heutigeFrage) {
          container.innerHTML = 'Fehler: Heutige Frage konnte nicht geladen werden.';
          return;
        }
        const datum = heute.toLocaleDateString('de-DE', {
          weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
        });
        let htmlContent = '<div class="quiz-card">';
        htmlContent += '<div class="quiz-header">';
        htmlContent += '<h3 class="quiz-title">Quiz des Tages</h3>';
        htmlContent += '<p class="quiz-datum">' + datum + '</p>';
        htmlContent += '</div>';
        htmlContent += '<div class="quiz-body">';
        htmlContent += '<p class="quiz-frage">' + heutigeFrage.frage + '</p>';
        if (heutigeFrage.typ === 'multiple-choice') {
          htmlContent += '<div class="quiz-optionen" role="group" aria-label="Antwortmöglichkeiten">';
          heutigeFrage.optionen.forEach(function(option, index) {
            htmlContent += '<button type="button" class="quiz-option" data-index="' + index + '">' + option + '</button>';
          });
          htmlContent += '</div>';
        } else if (heutigeFrage.typ === 'freitext') {
          htmlContent += '<div class="freitext-zeile">';
          htmlContent += '<input type="text" class="freitext-antwort" placeholder="Deine Antwort..." aria-label="Deine Antwort">';
          htmlContent += '<button type="button" class="freitext-pruefen">Prüfen</button>';
          htmlContent += '</div>';
        }
        htmlContent += '<div class="feedback-bereich" aria-live="polite" aria-atomic="true"></div>';
        htmlContent += '</div></div>';
        container.innerHTML = htmlContent;
        // Style-Element neu einfügen nach innerHTML-Reset
        injectQuizStyles();
        attachEventListeners();
      }

      function attachEventListeners() {
        if (heutigeFrage.typ === 'multiple-choice') {
          container.querySelectorAll('.quiz-option').forEach(function(button) {
            button.addEventListener('click', function() {
              checkAnswer(parseInt(this.dataset.index));
            });
          });
        } else if (heutigeFrage.typ === 'freitext') {
          const pruefenButton = container.querySelector('.freitext-pruefen');
          const textInput = container.querySelector('.freitext-antwort');
          if (pruefenButton && textInput) {
            pruefenButton.addEventListener('click', function() {
              checkAnswer(textInput.value);
            });
            textInput.addEventListener('keyup', function(event) {
              if (event.key === 'Enter') pruefenButton.click();
            });
          }
        }
      }

      function checkAnswer(userAnswer) {
        const feedbackBereich = container.querySelector('.feedback-bereich');
        let isCorrect = false;

        if (heutigeFrage.typ === 'multiple-choice') {
          isCorrect = (userAnswer === heutigeFrage.antwort);
          container.querySelectorAll('.quiz-option').forEach(function(b) {
            b.disabled = true;
          });
          // Richtige Antwort grün hervorheben
          const correctBtn = container.querySelector('[data-index="' + heutigeFrage.antwort + '"]');
          if (correctBtn) correctBtn.classList.add('antwort-highlight');
        } else if (heutigeFrage.typ === 'freitext') {
          isCorrect = (userAnswer.trim().toLowerCase() === heutigeFrage.antwort.toLowerCase());
          const input = container.querySelector('.freitext-antwort');
          const btn = container.querySelector('.freitext-pruefen');
          if (input) input.disabled = true;
          if (btn) btn.disabled = true;
        }

        if (isCorrect) {
          feedbackBereich.innerHTML = '<strong>\u2713 Richtig!</strong> ' + heutigeFrage.feedback;
          feedbackBereich.className = 'feedback-bereich feedback-korrekt';
        } else {
          let falschText = '<strong>\u2717 Leider falsch.</strong> ' + heutigeFrage.feedback;
          if (heutigeFrage.typ === 'freitext') {
            falschText += ' <em>Die richtige Antwort lautet: ' + heutigeFrage.antwort + '</em>';
          }
          feedbackBereich.innerHTML = falschText;
          feedbackBereich.className = 'feedback-bereich feedback-falsch';
        }
      }

      if (heutigeFrage) {
        quizAnzeigen();
      }
    })();
  </script>
</div>
